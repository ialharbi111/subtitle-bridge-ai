# ===== ضع مفاتيحك هنا ثم أعد تسمية الملف إلى .env =====

# مفتاح Gemini API الخاص بك (احصل عليه مجاناً من https://aistudio.google.com/apikey)
GEMINI_API_KEY=ضع_مفتاح_Gemini_هنا

# مفتاح OpenSubtitles API (سجّل مجاناً على https://www.opensubtitles.com/en/consumers ثم أنشئ API Key)
OPENSUBTITLES_API_KEY=ضع_مفتاح_OpenSubtitles_هنا

# (اختياري لكن يُفضّل) بيانات حساب OpenSubtitles لزيادة الحد اليومي للتحميل
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# البورت المحلي الذي يعمل عليه السيرفر
PORT=7000

# الرابط العام للسيرفر بعد رفعه (يُستخدم لبناء روابط ملفات الترجمة المترجمة)
# محلياً اتركه كما هو، وبعد النشر على Render/Railway ضع الرابط الحقيقي هنا
BASE_URL=http://127.0.0.1:7000
